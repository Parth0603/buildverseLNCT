# ScamRadar X - Environment Configuration Template

# FastAPI Port & Environment Settings (Optional)
PORT=8000
DEBUG=True

# Supabase / PostgreSQL Connection String
# Leave commented or blank to automatically use the local SQLite database fallback (sqlite:///./scamradar.db)
# DATABASE_URL=postgresql://postgres:your-supabase-password@db.your-supabase-ref.supabase.co:5432/postgres

# Google Gemini API Key (Required for AI Analysis, falls back to Regex-Heuristics engine if empty)
GEMINI_API_KEY=your_gemini_api_key_here

# AssemblyAI API Key (Required for Cloud Audio Transcription, falls back to Mock Dialogue Scripts if empty)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Optional Google Safe Browsing API Key
# SAFE_BROWSING_API_KEY=your_safe_browsing_key_here

# Blockchain Prep Settings (Polygon Amoy Testnet Integration Layer)
AMOY_TESTNET_RPC=https://rpc-amoy.polygon.technology
CONTRACT_ADDRESS=0x5B3DF5F000000000000000000000000000000000
